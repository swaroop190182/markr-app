{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/deliver",
      "schedule": "0 1 * * *"
    }
  ],
  "functions": {
    "api/deep-qa.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
